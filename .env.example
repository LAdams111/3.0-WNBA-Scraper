# Optional: POST scraped players to Hoop Central (batch size max 500 per request)
HOOP_CENTRAL_INGEST_URL=http://localhost:5000/api/ingest/players
INGEST_API_KEY=

# Gap between discovery batches (letter-page waves). Player scrape uses parallel workers instead.
DELAY_MS=800

# Parallel player page fetches (1–12). Default 4. Raise slowly if BR returns 429.
CONCURRENCY=4

# Parallel letter-directory fetches during discovery. Default 8.
DISCOVER_CONCURRENCY=8

# Optional: stop after N players (debug)
# SCRAPE_LIMIT=25

# Optional: only use /wnba/players/ main index (faster but incomplete vs a–z crawl)
# FAST_DISCOVER=1
