# POST scraped players to Hoop Central (body size limit set on backend; default one big batch).
HOOP_CENTRAL_INGEST_URL=http://localhost:5000/api/ingest/players
INGEST_API_KEY=

# Optional pause after discovery (ms). Default 0.
DELAY_MS=0

# Parallel BR workers (1–16). Default 4. Spacing is adaptive unless BR_ADAPTIVE=0.
CONCURRENCY=4

# Adaptive pacing (default on): tightens gap after OK streaks, widens on 429. Set BR_ADAPTIVE=0 for fixed gap only.
# BR_ADAPTIVE=0
# Target ms between starts when stable (also initial ceiling anchor). Default 520.
# BR_MIN_INTERVAL_MS=520
# Floor / ceiling for adaptive gap (ms). Defaults 260 / 2200.
# BR_GAP_FLOOR_MS=260
# BR_GAP_CEILING_MS=2200
# Shrink gap by this many ms every BR_ADAPTIVE_OK_STREAK successes (default 10 ok → −40 ms).
# BR_ADAPTIVE_SHRINK_MS=40
# BR_ADAPTIVE_OK_STREAK=10
# Multiply gap by this percent (÷100) after a 429. Default 135 (=×1.35).
# BR_ADAPTIVE_429_MULT=135

# undici connections to basketball-reference.com (8–128). Default 32.
# BR_CONNECTION_POOL=32

# Progress log every N successful scrapes. Default 1.
# SCRAPING_LOG_EVERY=5

# Ms pause after a round that still has failures (429 backoff). Default 1500.
# SCRAPER_ROUND_PAUSE_MS=1500

# Log a heartbeat while player pages are in flight (Railway looks “stuck” otherwise). Default 12000 ms.
# SCRAPER_HEARTBEAT_MS=12000

# Per-request timeout (ms). Default 45000.
# FETCH_TIMEOUT_MS=45000

# Parallel ingest POSTs (1–10). Default 6.
# INGEST_CONCURRENCY=6

# Max players per ingest POST (default: all in one request).
# INGEST_CHUNK_SIZE=500

# SCRAPE_LIMIT=25
# FAST_DISCOVER=1
