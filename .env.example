# POST scraped players to Hoop Central (body size limit set on backend; default one big batch).
HOOP_CENTRAL_INGEST_URL=http://localhost:5000/api/ingest/players
INGEST_API_KEY=

# Optional pause after discovery (ms). Default 0.
DELAY_MS=0

# Parallel BR workers (1–16). Default 2. Request *starts* are also spaced globally (BR_MIN_INTERVAL_MS).
CONCURRENCY=2

# Minimum ms between starting each BR request (all workers share one queue). Default 750.
# BR_MIN_INTERVAL_MS=750

# undici connections to basketball-reference.com (8–128). Default 32.
# BR_CONNECTION_POOL=32

# Progress log every N successful scrapes. Default 1.
# SCRAPING_LOG_EVERY=5

# Ms pause after a round that still has failures (429 backoff). Default 1500.
# SCRAPER_ROUND_PAUSE_MS=1500

# Per-request timeout (ms). Default 45000.
# FETCH_TIMEOUT_MS=45000

# Parallel ingest POSTs (1–10). Default 6.
# INGEST_CONCURRENCY=6

# Max players per ingest POST (default: all in one request).
# INGEST_CHUNK_SIZE=500

# SCRAPE_LIMIT=25
# FAST_DISCOVER=1
