# Ball Don’t Lie — required for scrape (see https://docs.balldontlie.io/)
# Never commit real keys; use Railway Variables or a local .env (gitignored).
# Railway: add as a Variable on THIS service (same tab as Deploy Logs). INGEST_API_KEY is different.
BALLDONTLIE_API_KEY=
# Optional aliases if you prefer shorter names:
# BDL_API_KEY=
# BALL_DONT_LIE_API_KEY=

# Optional. Default https://api.balldontlie.io/v1
# BALLDONTLIE_BASE_URL=https://api.balldontlie.io/v1

# Player list: "all" (default) or "active" → /players/active
# BDL_PLAYER_LIST=all

# Pagination / rate limit (free tier ~30 req/min): delay between pages (ms). Default 2100.
# BDL_REQUEST_DELAY_MS=2100
# BDL_PER_PAGE=100
# BDL_MAX_PAGES=10000

# After listing players, fetch /v1/season_averages/general (regular, type=base). Set to 0 to skip.
# BDL_FETCH_SEASON_STATS=1
# Season year as API expects (e.g. 2025 for 2025–26). Defaults from current calendar (Oct flip).
# BDL_STATS_SEASON=2025
# Player ids per season_averages request (max 100). Default 25.
# BDL_STATS_BATCH_SIZE=25
# Delay between season_averages batches (ms). Default 2100.
# BDL_STATS_REQUEST_DELAY_MS=2100

# Hoop Central ingest (npm run ingest / npm start second step)
# Must be reachable from THIS Railway service (public https URL to your backend, not localhost).
HOOP_CENTRAL_INGEST_URL=http://localhost:5000/api/ingest/players
INGEST_API_KEY=

# --- If Ball Dont Lie logs look fine but Mongo/site stay empty ---
# 1) npm start runs ingest ONLY after scrape fully finishes (all /players pages + season stats). Wait for
#    "=== Starting Hoop Central ingest" then "Ingesting …" / "Ingest complete."
# 2) Same Railway service needs HOOP_CENTRAL_INGEST_URL + INGEST_API_KEY (same values as backend expects).
# 3) Backend logs: look for 401/403/413 on POST /api/ingest/players.
# 4) Website may filter to WNBA only — NBA players use externalId prefix bdl-nba-*; update UI/query if needed.

# Parallel ingest POSTs (1–10). Default 6.
# INGEST_CONCURRENCY=6

# Max players per ingest POST (default: all in one request).
# INGEST_CHUNK_SIZE=500

# Optional: cap players when scraping (dev)
# SCRAPE_LIMIT=25
