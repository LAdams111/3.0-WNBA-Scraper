# Optional: POST scraped players to Hoop Central (batch size max 500 per request)
HOOP_CENTRAL_INGEST_URL=http://localhost:5000/api/ingest/players
INGEST_API_KEY=

# Gap between discovery batches (letter-page waves), ms.
DELAY_MS=250

# Parallel Basketball Reference player page fetches (1–12). Lower if you see HTTP 429.
CONCURRENCY=8

# Parallel letter-directory fetches during discovery (1–13).
DISCOVER_CONCURRENCY=13

# Per-request timeout when downloading a BR page (ms).
# FETCH_TIMEOUT_MS=60000

# Parallel ingest POSTs to your API (1–6). Default 4.
# INGEST_CONCURRENCY=4

# Optional: stop after N players (debug)
# SCRAPE_LIMIT=25

# Optional: only use /wnba/players/ main index (faster but incomplete vs a–z crawl)
# FAST_DISCOVER=1
